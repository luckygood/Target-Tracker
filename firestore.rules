rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == role;
    }

    function isFA() {
      return hasRole('fa_admin') || hasRole('fa_member') || 
        (request.auth.token.email == "parrotandy@gmail.com" && request.auth.token.email_verified == true);
    }

    function isAdmin() {
      return hasRole('fa_admin') || 
        (request.auth.token.email == "parrotandy@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Data Validation Helpers
    // ===============================================================
    function isValidProject(data) {
      return data.keys().hasAll(['title', 'code', 'description', 'stage', 'area', 'partneringStatus']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.code is string && data.code.size() > 0 && data.code.size() < 20;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      // Only the owner can read their own profile (PII protection)
      // Admins can also read profiles for management
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isFA();
      allow update: if isFA();
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isFA() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isFA();
    }

    match /inquiries/{inquiryId} {
      allow read: if isFA() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
